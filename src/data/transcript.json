[
  {
    "timestamp": "00:00:15",
    "text": {
      "CA": "At the left we can see...",
      "FR": "À gauche, on peut voir...",
      "ES": "A la izquierda podemos ver..."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:18",
    "text": {
      "CA": "At the right we can see the...",
      "FR": "À droite, on peut voir le...",
      "ES": "A la derecha podemos ver el..."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:20",
    "text": {
      "CA": "...the head-snarlers.",
      "FR": "...les têtes-enrouleurs.",
      "ES": "...los enroscadores de cabezas."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:21",
    "text": {
      "CA": "Everything is safe. Perfectly safe.",
      "FR": "Tout est sûr. Parfaitement sûr.",
      "ES": "Todo está seguro. Perfectamente seguro."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:24",
    "text": {
      "CA": "Emo?",
      "FR": "Emo?",
      "ES": "¿Emo?"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:28",
    "text": {
      "CA": "Watch out!",
      "FR": "Attention!",
      "ES": "¡Cuidado!"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:47",
    "text": {
      "CA": "Are you hurt?",
      "FR": "Es-tu blessé?",
      "ES": "¿Estás herido?"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:51",
    "text": {
      "CA": "I don't think so. You.",
      "FR": "Je ne pense pas. Toi.",
      "ES": "No lo creo. Tú."
    },
    "speaker": {
      "CA": "Emo",
      "FR": "Emoo",
      "ES": "Eemo"},
    "flagged": false
  },
  {
    "timestamp": "00:00:55",
    "text": {
      "CA": "I'm Ok.",
      "FR": "Je vais bien.",
      "ES": "Estoy bien."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:00:57",
    "text": {
      "CA": "Get up. Emo, it's not safe here.",
      "FR": "Lève-toi. Emo, ce n'est pas sûr ici.",
      "ES": "Levántate. Emo, aquí no es seguro."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:01:03",
    "text": {
      "CA": "Let's go.",
      "FR": "Allons-y.",
      "ES": "Vamos."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:01:05",
    "text": {
      "CA": "What's next?",
      "FR": "Qu'est-ce qu'il y a après?",
      "ES": "¿Qué sigue?"
    },
    "speaker": {
      "CA": "Emo",
      "FR": "Emoo",
      "ES": "Eemo"},
    "flagged": false
  },
  {
    "timestamp": "00:01:09",
    "text": {
      "CA": "You'll see!",
      "FR": "Tu verras!",
      "ES": "¡Lo verás!"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:01:16",
    "text": {
      "CA": "Emo. This way.",
      "FR": "Emo. Par ici.",
      "ES": "Emo. Por aquí."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:01:34",
    "text": {
      "CA": "Follow me!",
      "FR": "Suis-moi!",
      "ES": "¡Sígueme!"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:02:11",
    "text": {
      "CA": "Hurry Emo!",
      "FR": "Dépêche-toi Emo!",
      "ES": "¡Date prisa, Emo!"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:02:48",
    "text": {
      "CA": "You're not paying attention!",
      "FR": "Tu ne fais pas attention!",
      "ES": "¡No estás prestando atención!"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:02:50",
    "text": {
      "CA": "I just want to answer the... phone.",
      "FR": "Je veux juste répondre au... téléphone.",
      "ES": "Solo quiero contestar el... teléfono."
    },
    "speaker": {
      "CA": "Emo",
      "FR": "Emoo",
      "ES": "Eemo"},
    "flagged": false
  },
  {
    "timestamp": "00:02:54",
    "text": {
      "CA": "Emo, look, I mean listen.",
      "FR": "Emo, regarde, enfin écoute.",
      "ES": "Emo, mira, o sea, escucha."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:02:59",
    "text": {
      "CA": "You have to learn to listen.",
      "FR": "Tu dois apprendre à écouter.",
      "ES": "Tienes que aprender a escuchar."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:03:03",
    "text": {
      "CA": "This is not some game.",
      "FR": "Ce n'est pas un jeu.",
      "ES": "Esto no es un juego."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:03:05",
    "text": {
      "CA": "You, I mean we, we could easily die out here.",
      "FR": "Toi, enfin nous, on pourrait facilement mourir ici.",
      "ES": "Tú, o sea, nosotros, podríamos morir fácilmente aquí."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:03:10",
    "text": {
      "CA": "Listen, listen to the sounds of the machine.",
      "FR": "Écoute, écoute les sons de la machine.",
      "ES": "Escucha, escucha los sonidos de la máquina."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:03:18",
    "text": {
      "CA": "Listen to your breathing.",
      "FR": "Écoute ta respiration.",
      "ES": "Escucha tu respiración."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:04:27",
    "text": {
      "CA": "Well, don't you ever get tired of this?",
      "FR": "Eh bien, tu ne te lasses jamais de ça?",
      "ES": "Bueno, ¿nunca te cansas de esto?"
    },
    "speaker": {
      "CA": "Emo",
      "FR": "Emoo",
      "ES": "Eemo"},
    "flagged": false
  },
  {
    "timestamp": "00:04:29",
    "text": {
      "CA": "Tired?!?",
      "FR": "Las-tu?!?",
      "ES": "¿Cansado?!?"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:04:31",
    "text": {
      "CA": "Emo, the machine is like clockwork.",
      "FR": "Emo, la machine est comme une horloge.",
      "ES": "Emo, la máquina es como un reloj."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:04:37",
    "text": {
      "CA": "One move out of place... and you're ground to a pulp.",
      "FR": "Un mouvement hors de place... et tu es réduit en bouillie.",
      "ES": "Un movimiento fuera de lugar... y eres hecho pulpa."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:04:40",
    "text": {
      "CA": "But isn't it -",
      "FR": "Mais n'est-ce pas -",
      "ES": "¿Pero no es -"
    },
    "speaker": {
      "CA": "Emo",
      "FR": "Emoo",
      "ES": "Eemo"},
    "flagged": false
  },
  {
    "timestamp": "00:04:42",
    "text": {
      "CA": "Pulp, Emo! Is that what you want, pulp?",
      "FR": "De la pulpe, Emo! C'est ça que tu veux, de la pulpe?",
      "ES": "¡Pulpa, Emo! ¿Eso es lo que quieres, pulpa?"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:05:41",
    "text": {
      "CA": "Emo, close your eyes.",
      "FR": "Emo, ferme les yeux.",
      "ES": "Emo, cierra los ojos."
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:05:44",
    "text": {
      "CA": "Why? - Now!",
      "FR": "Pourquoi? - Maintenant!",
      "ES": "¿Por qué? - ¡Ahora!"
    },
    "speaker": "Emo / Proog",
    "flagged": false
  },
  {
    "timestamp": "00:05:51",
    "text": {
      "CA": "Ok.",
      "FR": "D'accord.",
      "ES": "Está bien."
    },
    "speaker": {
      "CA": "Emo",
      "FR": "Emoo",
      "ES": "Eemo"},
    "flagged": false
  },
  {
    "timestamp": "00:06:02",
    "text": {
      "CA": "What do you see at your left side, Emo?",
      "FR": "Que vois-tu à ta gauche, Emo?",
      "ES": "¿Qué ves a tu izquierda, Emo?"
    },
    "speaker": {
      "CA": "Proog",
      "FR": "Prog",
      "ES": "Prooɠ"},
    "flagged": false
  },
  {
    "timestamp": "00:06:04",
    "text": {
      "CA": "Nothing. - Really?",
      "FR": "Rien. - Vraiment?",
      "ES": "Nada. - ¿En serio?"
    },
    "speaker": "Emo / Proog",
    "flagged": false
  },
  {
    "timestamp": "00:06:13",
    "text": {
      "CA": "The same Proog, exactly the same... nothing! - Great.",
      "FR": "Le même Proog, exactement le même... rien! - Parfait.",
      "ES": "Lo mismo, Proog, exactamente lo mismo... ¡nada! - Genial."
    },
    "speaker": "Emo / Proog",
    "flagged": false
  }
]

