[
  {
    "timestamp": "00:00:15",
    "text": "At the left we can see...",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:18",
    "text": "At the right we can see the...",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:20",
    "text": "...the head-snarlers.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:21",
    "text": "Everything is safe. Perfectly safe.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:24",
    "text": "Emo?",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:28",
    "text": "Watch out!",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:47",
    "text": "Are you hurt?",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:51",
    "text": "I don't think so. You.",
    "speaker": "Emo",
    "flagged": false
  },
  {
    "timestamp": "00:00:55",
    "text": "I'm Ok.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:00:57",
    "text": "Get up. Emo, it's not safe here.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:01:03",
    "text": "Let's go.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:01:05",
    "text": "What's next?",
    "speaker": "Emo",
    "flagged": false
  },
  {
    "timestamp": "00:01:09",
    "text": "You'll see!",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:01:16",
    "text": "Emo. This way.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:01:34",
    "text": "Follow me!",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:02:11",
    "text": "Hurry Emo!",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:02:48",
    "text": "You're not paying attention!",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:02:50",
    "text": "I just want to answer the... phone.",
    "speaker": "Emo",
    "flagged": false
  },
  {
    "timestamp": "00:02:54",
    "text": "Emo, look, I mean listen.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:02:59",
    "text": "You have to learn to listen.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:03:03",
    "text": "This is not some game.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:03:05",
    "text": "You, I mean we, we could easily die out here.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:03:10",
    "text": "Listen, listen to the sounds of the machine.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:03:18",
    "text": "Listen to your breathing.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:04:27",
    "text": "Well, don't you ever get tired of this?",
    "speaker": "Emo",
    "flagged": false
  },
  {
    "timestamp": "00:04:29",
    "text": "Tired?!?",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:04:31",
    "text": "Emo, the machine is like clockwork.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:04:37",
    "text": "One move out of place... and you're ground to a pulp.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:04:40",
    "text": "But isn't it -",
    "speaker": "Emo",
    "flagged": false
  },
  {
    "timestamp": "00:04:42",
    "text": "Pulp, Emo! Is that what you want, pulp?",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:05:41",
    "text": "Emo, close your eyes.",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:05:44",
    "text": "Why? - Now!",
    "speaker": "Emo / Proog",
    "flagged": false
  },
  {
    "timestamp": "00:05:51",
    "text": "Ok.",
    "speaker": "Emo",
    "flagged": false
  },
  {
    "timestamp": "00:06:02",
    "text": "What do you see at your left side, Emo?",
    "speaker": "Proog",
    "flagged": false
  },
  {
    "timestamp": "00:06:04",
    "text": "Nothing. - Really?",
    "speaker": "Emo / Proog",
    "flagged": false
  },
  {
    "timestamp": "00:06:13",
    "text": "The same Proog, exactly the same... nothing! - Great.",
    "speaker": "Emo / Proog",
    "flagged": false
  }
]
